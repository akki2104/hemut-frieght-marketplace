# Copy to .env and fill in. The app runs without any of these set
# (email falls back to "recorded" instead of actually sending).

# SQLite by default; swap for a Postgres async URL to move off SQLite.
DATABASE_URL=sqlite+aiosqlite:///./freight.db

# Resend — real email sending. Get a key at https://resend.com
RESEND_API_KEY=
# The keyless sandbox sender only delivers to your Resend account's own email.
RESEND_FROM_EMAIL=onboarding@resend.dev

# CORS origin for the Next.js frontend.
FRONTEND_ORIGIN=http://localhost:3000

# JWT auth. Override the secret outside local dev — this default is insecure
# on purpose so a missing override is obvious rather than silently "working".
JWT_SECRET_KEY=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# Groq — AI historical rate suggestion shown in the Place Bid modal. Get a key
# at https://console.groq.com. Unset: the suggestion endpoint returns null.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
